# Discord bot token (Developer Portal -> your app -> Bot -> Reset Token)
DISCORD_TOKEN=

# Your application's Client ID (Developer Portal -> your app -> General Information -> Application ID)
DISCORD_CLIENT_ID=

# Your test server's ID (enable Developer Mode in Discord, right-click the server -> Copy Server ID)
GUILD_ID=

# MongoDB connection string (MongoDB Atlas -> Connect -> Drivers)
MONGODB_URI=
